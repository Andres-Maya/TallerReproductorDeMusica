{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist/backend",
    "rootDir": ".",
    "composite": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "moduleResolution": "node"
  },
  "include": ["backend/**/*", "Song.ts", "Playlist.ts", "TrackList.ts", "TrackNode.ts", "ApiResponse.ts", "paramHelper.ts", "errorHandler.ts", "app.ts", "server.ts", "index.ts", "PlaylistController.ts", "SongController.ts", "PlaylistManager.ts"],
  "exclude": ["node_modules", "dist", "backend/**/*.test.ts", "frontend/**/*", "vite.config.ts", "vitest.config.ts"]
}
