{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": ["ES2020"],
    "outDir": "./dist/backend",
    "rootDir": ".",
    "composite": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "moduleResolution": "node"
  },
  "include": ["backend/**/*", "*.ts"],
  "exclude": ["node_modules", "dist", "backend/**/*.test.ts", "frontend/**/*"]
}
