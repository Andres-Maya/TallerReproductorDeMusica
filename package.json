{
  "name": "waveline-backend",
  "version": "1.0.0",
  "description": "Waveline Music Playlist Player — REST API backend in TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only backend/server.ts",
    "dev:backend": "ts-node-dev --respawn --transpile-only backend/server.ts",
    "dev:frontend": "vite",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p tsconfig.backend.json",
    "build:frontend": "vite build",
    "start": "node dist/server.js",
    "test": "vitest --run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:backend": "tsc -p tsconfig.backend.json --noEmit",
    "typecheck:frontend": "tsc -p tsconfig.frontend.json --noEmit"
  },
  "keywords": [
    "music",
    "playlist",
    "typescript",
    "rest-api"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.2",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "typescript": "^5.5.2"
  },
  "devDependencies": {
    "@vitest/ui": "^4.1.4",
    "jsdom": "^29.0.2",
    "ts-node-dev": "^2.0.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
