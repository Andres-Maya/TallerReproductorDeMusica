# Backend Environment Variables
# =============================

# JWT Secret (REQUERIDO - mínimo 32 caracteres)
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-min-32-chars

# Node Environment
NODE_ENV=development

# Server Port
PORT=4000

# Data Directory (para almacenamiento de archivos JSON)
DATA_DIR=./data


# Frontend Environment Variables (Vite)
# ======================================

# URL del backend API
# Desarrollo local: http://localhost:4000
# Producción: https://tu-backend-desplegado.com
VITE_API_URL=http://localhost:4000


# Deployment Notes
# ================
# 
# Para GitHub Pages:
# - El frontend se despliega automáticamente en: https://tu-usuario.github.io/tu-repo
# - Debes desplegar el backend por separado (Render, Railway, Heroku, etc.)
# - Actualiza VITE_API_URL en el workflow de GitHub Actions con la URL de tu backend
#
# Para Vercel:
# - Configura estas variables en el dashboard de Vercel
# - El backend se despliega como serverless functions
#
# Para Netlify:
# - Configura estas variables en el dashboard de Netlify
# - El backend se despliega como Netlify Functions


# Storage Configuration
# ======================

# Storage backend type: local, s3, cloudinary
STORAGE_TYPE=local

# Local storage directory (when STORAGE_TYPE=local)
UPLOAD_DIR=./uploads

# Storage Limits
MAX_FILE_SIZE=52428800
STORAGE_QUOTA_PER_USER=104857600

# AWS S3 Configuration (when STORAGE_TYPE=s3)
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Cloudinary Configuration (when STORAGE_TYPE=cloudinary)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Rate Limiting
RATE_LIMIT_UPLOADS_PER_HOUR=10

# YouTube Integration
# ===================

# YouTube Data API v3 Key (OPCIONAL pero recomendado)
# Obtén una API key en: https://console.cloud.google.com
# 1. Crea un proyecto o usa uno existente
# 2. Habilita "YouTube Data API v3"
# 3. Crea credenciales (API Key)
# 4. Copia la key aquí
# Si no se configura, se usará ytdl-core como fallback (menos confiable)
# YOUTUBE_API_KEY=tu-youtube-api-key-aqui
